{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=nureassistant;Username=nureassistant;Password=nureassistant"
  },
  "JwtTokenSettings": {
    "Issuer": "NureAssistant",
    "Audience": "NureAssistantClients",
    "Key": "CHANGE_ME_super_secret_jwt_key_at_least_32_chars_long!!",
    "TokenLifespanInMinutes": 60
  }     
}
